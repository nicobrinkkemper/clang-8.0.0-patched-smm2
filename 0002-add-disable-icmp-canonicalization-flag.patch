+
 using namespace llvm;
 using namespace PatternMatch;
 
@@ -4557,6 +4562,9 @@
 static ICmpInst *canonicalizeCmpWithConstant(ICmpInst &I) {
   ICmpInst::Predicate Pred = I.getPredicate();
