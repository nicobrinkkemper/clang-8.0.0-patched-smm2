 #include "llvm/Transforms/InstCombine/InstCombineWorklist.h"
 
+static cl::opt<bool> DisableICmpCanonicalization(
+    "disable-icmp-canonicalization",
+    cl::desc("Disable canonicalization of >= to > in integer comparisons"),
